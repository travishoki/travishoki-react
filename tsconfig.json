{
	"compilerOptions": {
		"allowJs": true,
		"jsx": "react",
		"module": "esnext",
		"moduleResolution": "bundler",
		"noEmit": true,
		"skipLibCheck": true,
		"strict": true,
		"baseUrl": ".",
		"esModuleInterop": true,
		"typeRoots": ["node_modules/@types", "src/types"],
		"paths": {
			"~actions/*": ["./src/redux/actions/*"],
			"~components/*": ["./src/components/*"],
			"~const/*": ["./src/const/*"],
			"~helpers/*": ["./src/helpers/*"],
			"~images/*": ["./src/images/*"],
			"~reducers/*": ["./src/redux/reducers/*"],
			"~svg/*": ["./src/svg/*"]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules"]
}
